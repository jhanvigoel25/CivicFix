# CivicFix Environment Variables
# Copy this file to env.js and fill in your real keys.
#
# GOOGLE_AI_STUDIO_KEY — Gemini API key for image classification & voice transcription
#   Get one at: https://aistudio.google.com/app/apikey
#
# GOOGLE_MAPS_KEY — Google Maps JavaScript API key
#   Get one at: https://console.cloud.google.com/apis/credentials
#   Enable: Maps JavaScript API, and restrict by HTTP referrer.
#
GOOGLE_AI_STUDIO_KEY=YOUR_GOOGLE_AI_STUDIO_KEY
GOOGLE_MAPS_KEY=YOUR_GOOGLE_MAPS_KEY
